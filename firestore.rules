rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (required, enum: ['admin', 'employee', 'superuser'])
    //   - createdAt: timestamp
    //
    // Collection: projects
    // Document ID: projectId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - description: string
    //   - createdBy: string (required)
    //   - createdAt: timestamp
    //
    // Collection: tasks
    // Document ID: taskId
    // Fields:
    //   - id: string (required)
    //   - projectId: string (required)
    //   - title: string (required)
    //   - description: string
    //   - completionPercentage: number (required, 0-100)
    //   - deadline: string (date)
    //   - assignedTo: string (required)
    //   - assignedBy: string (required)
    //   - date: string (required, date)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         getUserData().role == 'superuser' ||
         (request.auth.token.email == "rohaniskhati@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperuser() {
      return isAuthenticated() && 
        (getUserData().role == 'superuser' ||
         (request.auth.token.email == "rohaniskhati@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'employee', 'superuser'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'createdBy', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdBy is string &&
             data.createdAt is timestamp;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'completionPercentage', 'assignedTo', 'assignedBy', 'date', 'createdAt']) &&
             data.id is string &&
             (!('projectId' in data) || data.projectId is string) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.completionPercentage is number && data.completionPercentage >= 0 && data.completionPercentage <= 100 &&
             data.assignedTo is string &&
             data.assignedBy is string &&
             data.date is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'employee' || isSuperuser());
      allow update: if isAuthenticated() && (isSuperuser() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isSuperuser();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isSuperuser();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && 
        (isAdmin() || (request.auth.uid == resource.data.assignedTo && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completionPercentage', 'description']))) &&
        isValidTask(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
